rules_version = '2';

// FLOQR STORAGE RULES VERSION: v28.57-storage-media-rules
// EXPECTED DEPLOYED STORAGE RULES VERSION: v28.57-storage-media-rules or newer
// Required media paths:
// - shoutouts/{uid}/... for original, enhanced, and trimmed ShoutOut media
// - profileMedia/{uid}/images/... and profileMedia/{uid}/videos/...
// - template-backgrounds/{uid}/{variantId}/... for patron template background media
// If Firebase Console Storage Rules does not show this note near the top, Storage rules are not updated to this package.

service firebase.storage {
  match /b/{bucket}/o {

    match /shoutouts/{userId}/{allPaths=**} {
      allow read: if request.auth != null;

      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 30 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*') ||
          request.resource.contentType.matches('video/.*')
        );
    }

    match /profileMedia/{userId}/images/{allPaths=**} {
      allow read: if request.auth != null;

      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /profileMedia/{userId}/videos/{allPaths=**} {
      allow read: if request.auth != null;

      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 60 * 1024 * 1024
        && request.resource.contentType.matches('video/.*');
    }

    match /template-backgrounds/{userId}/{variantId}/{allPaths=**} {
      allow read: if request.auth != null;

      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
