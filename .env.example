# FLOQR_EMAIL_OTP_FROM=
# FLOQR_GEMINI_MODEL=
# FUNCTIONS_EMULATOR=true

# GitHub Actions deploy (repo secret)
# FIREBASE_TOKEN=   # from: firebase login:ci
