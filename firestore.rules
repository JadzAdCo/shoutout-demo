rules_version = '2';

// FLOQR FIRESTORE RULES VERSION: v29.09.5-floqr-platform-payments
// EXPECTED DEPLOYED RULES VERSION: v29.09.5-floqr-platform-payments or newer
// PREVIOUS PACKAGE MARKER RETAINED FOR DIAGNOSTICS: FLOQR FIRESTORE RULES VERSION: v29.09.4-app-logging
// PREVIOUS PACKAGE MARKER RETAINED FOR DIAGNOSTICS: FLOQR FIRESTORE RULES VERSION: v28.86-mingl-message-action-rules
// PREVIOUS PACKAGE MARKER RETAINED FOR DIAGNOSTICS: FLOQR FIRESTORE RULES VERSION: v28.82-mingl-request-chat-rules
// PREVIOUS PACKAGE MARKER RETAINED FOR DIAGNOSTICS: FLOQR FIRESTORE RULES VERSION: v28.74-gemini-media-editing-rules
// PREVIOUS PACKAGE MARKER RETAINED FOR DIAGNOSTICS: FLOQR FIRESTORE RULES VERSION: v28.70-duplicate-alias-rules
// PREVIOUS PACKAGE MARKER RETAINED FOR DIAGNOSTICS: FLOQR FIRESTORE RULES VERSION: v28.59-diagnostic-cleanup-rules
// PREVIOUS PACKAGE MARKER RETAINED FOR DIAGNOSTICS: FLOQR FIRESTORE RULES VERSION: v28.57-mingl-diagnostic-rules
// Last required Firestore rules update added/confirmed:
// - clubLocationAliases read/write support for Master Admin duplicate record merge aliases
// - aiMediaEdits owner-visible audit records for Gemini ShoutOut image editing
// - users/{uid} self create/read/update support for onboarding and existing profiles
// - aiCrawlRuns, aiCrawlerSchedules, aiDiagnosticsReports for Master Admin Diagnostics
// - aiIndex, AI notification/preferences, assistant, patron/club template variant, prompt history, Mingl, and chat rule blocks
// - diagnosticRunId-scoped cleanup for temporary Mingl/chat rules smoke-test documents
// - explicit diagnostic-only delete support for temporary Mingl connection records
// - Mingl request audit records, system request messages, and sender-only message edit/action metadata support
// - Mingl read receipts so participants can mark incoming messages read without broad chat access
// - clubOnboardingRecords, promoterOnboardingRecords, clubMedia, and guestListCampaigns for venue onboarding
// - commerce, paid service orders, entity follows, role permissions/activity, staffing requests, campaigns, and Pickup simulations
// - backend-only Stripe Accounts v2 bindings, seller-scoped products, and owner/seller/admin order access
// If Firebase Console does not show this note near the top, Firestore rules are not updated to this package.

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isMasterAdmin() {
      return signedIn()
        && (
          request.auth.token.masterAdmin == true
          || request.auth.token.email in [
            "bands.don@gmail.com",
            "bans.don@gmail.com",
            "don.b@jadzholdings.com"
          ]
        );
    }

    function isClubManager(clubId) {
      return signedIn()
        && exists(/databases/$(database)/documents/clubLocations/$(clubId))
        && (
          isMasterAdmin()
          || (
            get(/databases/$(database)/documents/clubLocations/$(clubId)).data.adminUids is list
            && request.auth.uid in get(/databases/$(database)/documents/clubLocations/$(clubId)).data.adminUids
          )
          || (
            get(/databases/$(database)/documents/clubLocations/$(clubId)).data.masterAdminUids is list
            && request.auth.uid in get(/databases/$(database)/documents/clubLocations/$(clubId)).data.masterAdminUids
          )
          || (
            request.auth.token.email is string
            && get(/databases/$(database)/documents/clubLocations/$(clubId)).data.adminEmails is list
            && request.auth.token.email in get(/databases/$(database)/documents/clubLocations/$(clubId)).data.adminEmails
          )
          || (
            exists(/databases/$(database)/documents/clubAdminAssignments/$(clubId + "_" + request.auth.uid))
            && get(/databases/$(database)/documents/clubAdminAssignments/$(clubId + "_" + request.auth.uid)).data.status == "active"
          )
        );
    }

    function hasBackendOnlyIdentityFields(data) {
      return data.keys().hasAny([
        "masterAdmin",
        "roles",
        "approvedRoles",
        "approvedLocations",
        "stripeConnectAccountId",
        "stripeConnectStatus",
        "stripeConnectCapabilityStatus",
        "stripeConnectLivemode",
        "stripeConnectUpdatedAt"
      ]);
    }

    function preservesBackendOnlyIdentityFields() {
      return !request.resource.data.diff(resource.data).changedKeys().hasAny([
        "masterAdmin",
        "roles",
        "approvedRoles",
        "approvedLocations",
        "stripeConnectAccountId",
        "stripeConnectStatus",
        "stripeConnectCapabilityStatus",
        "stripeConnectLivemode",
        "stripeConnectUpdatedAt"
      ]);
    }

    function preservesStripeBindingFields() {
      return !request.resource.data.diff(resource.data).changedKeys().hasAny([
        "stripeConnectAccountId",
        "stripeConnectStatus",
        "stripeConnectCapabilityStatus",
        "stripeConnectLivemode",
        "stripeConnectUpdatedAt"
      ]);
    }

    function validNewCommerceProduct() {
      return signedIn()
        && request.resource.data.sellerUid == request.auth.uid
        && request.resource.data.sellerEntityId is string
        && (
          request.resource.data.sellerEntityId == request.auth.uid
          || (
            request.resource.data.sellerEntityType == "club"
            && isClubManager(request.resource.data.sellerEntityId)
          )
        )
        && !request.resource.data.keys().hasAny(["stripeConnectAccountId", "connectedAccountId", "paymentStatus"])
        && request.resource.data.keys().hasOnly([
          "sellerEntityId",
          "sellerEntityType",
          "sellerUid",
          "sellerName",
          "name",
          "category",
          "productType",
          "previewMediaType",
          "mediaLicense",
          "priceCents",
          "inventory",
          "imageUrl",
          "description",
          "requiresShipping",
          "active",
          "createdAt",
          "updatedAt"
        ]);
    }

    function isCommerceProductManager() {
      return signedIn()
        && (
          isMasterAdmin()
          || resource.data.sellerUid == request.auth.uid
          || resource.data.sellerEntityId == request.auth.uid
          || (
            resource.data.sellerEntityType == "club"
            && isClubManager(resource.data.sellerEntityId)
          )
        );
    }

    function isCommerceProductUpdate() {
      return isCommerceProductManager()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "sellerName",
          "name",
          "category",
          "productType",
          "previewMediaType",
          "mediaLicense",
          "priceCents",
          "inventory",
          "imageUrl",
          "description",
          "requiresShipping",
          "active",
          "updatedAt"
        ]);
    }

    function isServiceOrderReader() {
      return signedIn()
        && (
          isMasterAdmin()
          || (
            resource.data.keys().hasAny(["ownerUid"])
            && resource.data.ownerUid == request.auth.uid
          )
          || (
            resource.data.keys().hasAny(["sellerUid"])
            && resource.data.sellerUid == request.auth.uid
          )
          || (
            resource.data.keys().hasAny(["sellerEntityId"])
            && resource.data.sellerEntityId == request.auth.uid
          )
          || (
            resource.data.sellerEntityType == "club"
            && resource.data.sellerEntityId is string
            && isClubManager(resource.data.sellerEntityId)
          )
          || (
            resource.data.clubLocationId is string
            && isClubManager(resource.data.clubLocationId)
          )
        );
    }

    function isMasterFulfillmentUpdate() {
      return isMasterAdmin()
        && request.resource.data.updatedByUid == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "shippingStatus",
          "fulfillmentStatus",
          "shippingCarrier",
          "trackingNumber",
          "trackingUrl",
          "updatedByUid",
          "updatedAt"
        ]);
    }

    function createsOwnUid() {
      return signedIn()
        && request.resource.data.uid is string
        && request.resource.data.uid == request.auth.uid;
    }

    function ownsResourceUid() {
      return signedIn()
        && resource.data.uid is string
        && resource.data.uid == request.auth.uid;
    }

    function isParticipant() {
      return signedIn()
        && resource.data.participants is list
        && request.auth.uid in resource.data.participants;
    }

    function isNewParticipant() {
      return signedIn()
        && request.resource.data.participants is list
        && request.auth.uid in request.resource.data.participants;
    }

    function isDiagnosticResource() {
      return signedIn()
        && resource.data.diagnosticRunId is string;
    }

    function isDiagnosticParticipantResource() {
      return isDiagnosticResource()
        && resource.data.participants is list
        && request.auth.uid in resource.data.participants;
    }

    function isDiagnosticParticipantRequest() {
      return signedIn()
        && request.resource.data.diagnosticRunId is string
        && request.resource.data.participants is list
        && request.auth.uid in request.resource.data.participants;
    }

    function isMutualMingl(connectionId) {
      return signedIn()
        && exists(/databases/$(database)/documents/minglConnections/$(connectionId))
        && get(/databases/$(database)/documents/minglConnections/$(connectionId)).data.status == "mutual"
        && (
          (
            get(/databases/$(database)/documents/minglConnections/$(connectionId)).data.participants is list
            && request.auth.uid in get(/databases/$(database)/documents/minglConnections/$(connectionId)).data.participants
          ) ||
          get(/databases/$(database)/documents/minglConnections/$(connectionId)).data.requestedBy == request.auth.uid ||
          get(/databases/$(database)/documents/minglConnections/$(connectionId)).data.requestedTo == request.auth.uid
        );
    }

    function isExistingMinglRoom() {
      return resource.data.type == "mingl";
    }

    function isNewMinglRoom() {
      return request.resource.data.type == "mingl";
    }

    function isExistingMinglMessage() {
      return resource.data.keys().hasAny(["roomType"])
        && resource.data.roomType == "mingl";
    }

    function isNewMinglMessage() {
      return request.resource.data.keys().hasAny(["roomType"])
        && request.resource.data.roomType == "mingl";
    }

    function isMinglSystemMessageRequest() {
      return isNewMinglMessage()
        && request.resource.data.senderUid == "system"
        && request.resource.data.messageType in ["system", "backgroundConsent"]
        && request.resource.data.participants is list
        && request.auth.uid in request.resource.data.participants;
    }

    function isOwnMinglMessageEdit() {
      return isExistingMinglMessage()
        && resource.data.senderUid == request.auth.uid
        && request.resource.data.senderUid == resource.data.senderUid
        && request.resource.data.roomId == resource.data.roomId
        && request.resource.data.roomType == resource.data.roomType
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "body",
          "edited",
          "editedAt",
          "updatedAt",
          "aiGrammarApplied",
          "animationType",
          "animatedAt",
          "unsent",
          "deleteAfterRead",
          "deleteAfterReadSetAt"
        ]);
    }

    function isMinglDeleteAfterReadExpiry() {
      return isExistingMinglMessage()
        && resource.data.deleteAfterRead == true
        && resource.data.deletedAfterRead != true
        && resource.data.participants is list
        && request.auth.uid in resource.data.participants
        && resource.data.senderUid != request.auth.uid
        && request.resource.data.senderUid == resource.data.senderUid
        && request.resource.data.roomId == resource.data.roomId
        && request.resource.data.roomType == resource.data.roomType
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.body == "Message deleted after read."
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "body",
          "deletedAfterRead",
          "expiredAt",
          "expiredByUid",
          "updatedAt"
        ]);
    }

    function isMinglReadReceiptUpdate() {
      return isExistingMinglMessage()
        && resource.data.participants is list
        && request.auth.uid in resource.data.participants
        && resource.data.senderUid != request.auth.uid
        && request.resource.data.senderUid == resource.data.senderUid
        && request.resource.data.roomId == resource.data.roomId
        && request.resource.data.roomType == resource.data.roomType
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.readBy is map
        && request.resource.data.readAtBy is map
        && request.resource.data.readBy[request.auth.uid] == true
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "readBy",
          "readAtBy",
          "updatedAt"
        ]);
    }

    function isMinglBackgroundConsentUpdate() {
      return isExistingMinglMessage()
        && resource.data.messageType == "backgroundConsent"
        && resource.data.backgroundTargetUid == request.auth.uid
        && request.resource.data.senderUid == resource.data.senderUid
        && request.resource.data.roomId == resource.data.roomId
        && request.resource.data.roomType == resource.data.roomType
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "backgroundConsentStatus",
          "responseByUid",
          "respondedAt",
          "updatedAt"
        ]);
    }

    match /users/{userId} {
      allow create: if isSelf(userId)
        && !hasBackendOnlyIdentityFields(request.resource.data);
      allow read: if signedIn();
      allow update: if isSelf(userId)
        && preservesBackendOnlyIdentityFields();
      allow delete: if isParticipant()
        && isDiagnosticResource();
    }

    match /clubs/{id} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /clubLocations/{id} {
      allow read: if true;
      allow create: if isMasterAdmin()
        && !request.resource.data.keys().hasAny([
          "stripeConnectAccountId",
          "stripeConnectStatus",
          "stripeConnectCapabilityStatus",
          "stripeConnectLivemode",
          "stripeConnectUpdatedAt"
        ]);
      allow update: if (isMasterAdmin() || isClubManager(id))
        && preservesStripeBindingFields();
      allow delete: if isMasterAdmin();
    }

    match /clubLocationAliases/{aliasId} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /clubAdminAssignments/{assignmentId} {
      allow read: if isMasterAdmin()
        || resource.data.patronUid == request.auth.uid
        || (
          resource.data.clubLocationId is string
          && isClubManager(resource.data.clubLocationId)
        )
        || (
          resource.data.clubId is string
          && isClubManager(resource.data.clubId)
        );
      allow create: if isMasterAdmin()
        || (
          request.resource.data.clubLocationId is string
          && isClubManager(request.resource.data.clubLocationId)
        )
        || (
          request.resource.data.clubId is string
          && isClubManager(request.resource.data.clubId)
        );
      allow update, delete: if isMasterAdmin()
        || (
          resource.data.clubLocationId is string
          && isClubManager(resource.data.clubLocationId)
        )
        || (
          resource.data.clubId is string
          && isClubManager(resource.data.clubId)
        );
    }

    // OTP challenges contain hashes and rate-limit data; clients never read or write them.
    match /emailOtpChallenges/{challengeId} {
      allow read, write: if false;
    }

    match /events/{id} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /templates/{id} {
      allow read: if true;
      allow write: if isMasterAdmin();
    }

    function validPatronShoutoutCreate() {
      return signedIn()
        && request.resource.data.keys().hasAll([
          'template', 'screenFormatId', 'mainText', 'subText', 'submittedByUid',
          'maxMainCharacters', 'maxSubCharacters', 'lineCount', 'maxCharactersPerLine'
        ])
        && request.resource.data.template == 'blackwhite'
        && request.resource.data.submittedByUid == request.auth.uid
        && request.resource.data.mainText is string
        && request.resource.data.subText is string
        && request.resource.data.lineCount == 3
        && (
          ((request.resource.data.screenFormatId == 'p125-96x48' || request.resource.data.screenFormatId == 'led-96x48')
            && request.resource.data.mainText.size() <= 47
            && request.resource.data.subText.size() <= 20
            && request.resource.data.maxMainCharacters == 45
            && request.resource.data.maxCharactersPerLine == 15)
          || (request.resource.data.screenFormatId == 'p125-64x32'
            && request.resource.data.mainText.size() <= 44
            && request.resource.data.subText.size() <= 18
            && request.resource.data.maxMainCharacters == 42
            && request.resource.data.maxCharactersPerLine == 14)
          || ((request.resource.data.screenFormatId == 'p125-64x48' || request.resource.data.screenFormatId == 'led-64x48')
            && request.resource.data.mainText.size() <= 38
            && request.resource.data.subText.size() <= 18
            && request.resource.data.maxMainCharacters == 36
            && request.resource.data.maxCharactersPerLine == 12)
          || (request.resource.data.screenFormatId == 'led-64x32'
            && request.resource.data.mainText.size() <= 38
            && request.resource.data.subText.size() <= 16
            && request.resource.data.maxMainCharacters == 36
            && request.resource.data.maxCharactersPerLine == 12)
        );
    }

    // Free (no priceCents) templates other than Traditional B&W and paid football.
    function validFreePatronShoutoutCreate() {
      return signedIn()
        && request.resource.data.keys().hasAll(['template', 'mainText', 'submittedByUid'])
        && request.resource.data.template is string
        && request.resource.data.template != 'blackwhite'
        && request.resource.data.template != 'zebbiesFootballTeamIntro'
        && request.resource.data.submittedByUid == request.auth.uid
        && request.resource.data.mainText is string
        && request.resource.data.mainText.size() <= 120;
    }

    match /shoutouts/{id} {
      allow create: if validPatronShoutoutCreate() || validFreePatronShoutoutCreate();
      allow read, update, delete: if signedIn();
    }

    match /liveContent/{id} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /guestListRequests/{id} {
      allow create: if signedIn();
      allow read, update, delete: if signedIn();
    }

    match /guestListCampaigns/{id} {
      allow read: if true;
      allow create, update, delete: if signedIn();
    }

    match /commerceProducts/{id} {
      allow read: if true;
      allow create: if validNewCommerceProduct();
      allow update: if isCommerceProductUpdate();
      allow delete: if isCommerceProductManager();
    }

    match /serviceOrders/{id} {
      allow read: if isServiceOrderReader();
      allow create, delete: if false;
      allow update: if isMasterFulfillmentUpdate();
    }

    // Operational application logs for Master Admin Logging.
    match /appLogs/{id} {
      allow create: if signedIn()
        && request.resource.data.keys().hasAll(['level', 'category', 'message', 'uid', 'createdAt'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.level in ['debug', 'info', 'warn', 'error']
        && request.resource.data.category is string
        && request.resource.data.category.size() <= 80
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 2000;
      allow read: if isMasterAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid);
      allow update: if false;
      allow delete: if isMasterAdmin();
    }

    // FloqR platform payment ledger (ShoutOut and future FloqR-sold services). Backend writes only.
    match /paymentLedger/{id} {
      allow read: if isMasterAdmin()
        || (
          resource.data.clubLocationId is string
          && isClubManager(resource.data.clubLocationId)
        );
      allow create, update, delete: if false;
    }

    // Stripe account IDs, capability state, and webhook claims are backend-only.
    match /stripeConnectAccounts/{id} {
      allow read, write: if false;
    }

    match /stripeWebhookEvents/{id} {
      allow read, write: if false;
    }

    match /entityFollows/{id} {
      allow read, create, update, delete: if signedIn();
    }

    match /audienceCampaigns/{id} {
      allow read, create, update, delete: if signedIn();
    }

    match /pickupRequests/{id} {
      allow read, create, update, delete: if signedIn();
    }

    match /clubRolePolicies/{id} {
      allow read, create, update, delete: if signedIn();
    }

    match /clubRoleActivity/{id} {
      allow read, create, update, delete: if signedIn();
    }

    match /clubNotificationSettings/{id} {
      allow read, create, update, delete: if signedIn();
    }
    match /clubMessagingCredits/{id} {
      allow read: if signedIn();
      allow create, update, delete: if false;
    }
    match /clubMarketingCampaigns/{id} {
      allow read, create, update, delete: if signedIn();
    }
    match /clubDailyAuthCodes/{id} {
      allow read, create, update, delete: if signedIn();
    }

    match /clubMessageDeliveries/{id} {
      allow read, create, update, delete: if signedIn();
    }

    match /clubMessageInbound/{id} {
      allow read, create, update, delete: if signedIn();
    }

    match /workerAssociationRequests/{id} {
      allow read, create, update, delete: if signedIn();
    }

    match /clubAdminNotifications/{id} {
      allow read, create, update, delete: if signedIn();
    }

    match /clubOnboardingRecords/{id} {
      allow read, create, update, delete: if signedIn();
    }

    match /promoterOnboardingRecords/{id} {
      allow read, create, update, delete: if signedIn();
    }

    match /clubMedia/{id} {
      allow read: if true;
      allow create, update, delete: if signedIn();
    }

    match /messages/{id} {
      allow create, read, update, delete: if signedIn();
    }

    match /privacyConsents/{id} {
      allow create, read, update, delete: if signedIn();
    }

    match /friendRequests/{id} {
      allow create, read, update, delete: if signedIn();
    }

    match /friendships/{id} {
      allow create, read, update, delete: if signedIn();
    }

    match /notifications/{id} {
      allow create, read, update, delete: if signedIn();
    }

    match /roleRequests/{id} {
      allow create, read, update, delete: if signedIn();
    }

    match /clubEmployeeDesignations/{id} {
      allow create, read, update, delete: if signedIn();
    }

    match /patronRanks/{id} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /approvedShoutOutLibrary/{id} {
      allow read: if true;
      allow create, update, delete: if signedIn();
    }

    match /translationSettings/{id} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /inboxNotifications/{id} {
      allow create, read, update, delete: if signedIn();
    }

    match /shoutoutAudit/{id} {
      allow create, read, update, delete: if signedIn();
    }

    match /djProfiles/{id} {
      allow read: if true;
      allow create, update, delete: if signedIn();
    }

    match /promoterProfiles/{id} {
      allow read: if true;
      allow create, update, delete: if signedIn();
    }

    match /shoutoutRecommendations/{id} {
      allow read: if isMasterAdmin()
        || (
          signedIn()
          && (
            resource.data.status == "approved"
            || resource.data.uid == request.auth.uid
          )
        );
      allow create: if isMasterAdmin()
        || (
          signedIn()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.status == "pending"
        );
      allow update, delete: if isMasterAdmin();
    }

    match /aiIndex/{id} {
      allow read: if resource.data.visibility == "public"
        || (
          signedIn()
          && (
            resource.data.ownerUid == request.auth.uid
            || resource.data.visibility == "shared"
          )
        );
      allow create, update: if signedIn()
        && request.resource.data.visibility in ["public", "shared", "private"];
      allow delete: if signedIn();
    }

    match /aiUserNotificationPreferences/{uid} {
      allow read, write: if isSelf(uid);
    }

    match /aiUserSignals/{id} {
      allow create: if createsOwnUid();
      allow read, update, delete: if ownsResourceUid();
    }

    match /aiSearchLogs/{id} {
      allow create: if createsOwnUid();
      allow read, update, delete: if ownsResourceUid();
    }

    match /aiRecommendations/{id} {
      allow create: if signedIn();
      allow read, update, delete: if signedIn()
        && (
          resource.data.uid == request.auth.uid
          || resource.data.recipientUid == request.auth.uid
        );
    }

    match /aiMediaEdits/{id} {
      allow read, update, delete: if ownsResourceUid();
      allow create: if createsOwnUid();
    }

    match /aiDiscoverySources/{id} {
      allow read, write: if signedIn();
    }

    match /aiDiscoveryQueue/{id} {
      allow read, write: if signedIn();
    }

    match /aiDiscoveryRatingCriteria/{id} {
      allow read, write: if signedIn();
    }

    match /aiCrawlRuns/{id} {
      allow read, write: if signedIn();
    }

    match /aiCrawlerSchedules/{id} {
      allow read, write: if signedIn();
    }

    match /aiDiagnosticsReports/{id} {
      allow read, write: if signedIn();
    }

    match /aiAssistantSessions/{uid} {
      allow read, write: if isSelf(uid);
    }

    match /aiAssistantMessages/{id} {
      allow create: if createsOwnUid();
      allow read, update, delete: if ownsResourceUid();
    }

    match /patronTemplateVariants/{variantId} {
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid;

      allow read: if signedIn()
        && (
          resource.data.ownerUid == request.auth.uid ||
          resource.data.visibility == "public"
        );

      allow update, delete: if signedIn()
        && resource.data.ownerUid == request.auth.uid;
    }

    match /clubTemplateVariants/{variantId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.variantScope == "club"
        && request.resource.data.clubLocationId is string;

      allow update, delete: if signedIn();
    }

    match /aiTemplatePromptHistory/{id} {
      allow create: if createsOwnUid();
      allow read, update, delete: if ownsResourceUid();
    }

    match /minglConnections/{connectionId} {
      allow read: if isParticipant()
        || (
          signedIn()
          && (
            resource.data.requestedBy == request.auth.uid ||
            resource.data.requestedTo == request.auth.uid
          )
        );
      allow create: if isNewParticipant()
        && request.resource.data.participants.size() == 2
        && request.auth.uid == request.resource.data.requestedBy;
      allow update: if isParticipant()
        && request.resource.data.participants == resource.data.participants
        && (
          request.auth.uid == resource.data.requestedTo ||
          request.auth.uid == resource.data.requestedBy
        );
      allow delete: if isDiagnosticParticipantResource();
    }

    match /minglAudit/{id} {
      allow create: if signedIn()
        && request.resource.data.participants is list
        && request.auth.uid in request.resource.data.participants;
      allow read: if signedIn()
        && resource.data.participants is list
        && request.auth.uid in resource.data.participants;
      allow update, delete: if signedIn()
        && resource.data.actorUid == request.auth.uid;
    }

    match /chatRooms/{roomId} {
      allow read: if signedIn()
        && (
          isParticipant() ||
          !isExistingMinglRoom()
        );
      allow create: if signedIn()
        && (
          (
            isNewMinglRoom()
            && isNewParticipant()
            && request.resource.data.connectionId is string
            && isMutualMingl(request.resource.data.connectionId)
          ) ||
          !isNewMinglRoom()
        );
      allow update: if signedIn()
        && (
          (
            isExistingMinglRoom()
            && isParticipant()
            && resource.data.connectionId is string
            && isMutualMingl(resource.data.connectionId)
          ) ||
          !isExistingMinglRoom()
        );
      allow delete: if signedIn()
        && (
          !isExistingMinglRoom() ||
          (isExistingMinglRoom() && isDiagnosticParticipantResource())
        );
    }

    match /chatMessages/{messageId} {
      allow read: if signedIn()
        && (
          (
            isExistingMinglMessage()
            && resource.data.participants is list
            && request.auth.uid in resource.data.participants
          ) ||
          !isExistingMinglMessage()
        );
      allow create: if signedIn()
        && (
          (
            isNewMinglMessage()
            && (
              request.auth.uid == request.resource.data.senderUid ||
              isMinglSystemMessageRequest()
            )
            && request.resource.data.participants is list
            && request.auth.uid in request.resource.data.participants
            && exists(/databases/$(database)/documents/chatRooms/$(request.resource.data.roomId))
            && get(/databases/$(database)/documents/chatRooms/$(request.resource.data.roomId)).data.type == "mingl"
            && request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(request.resource.data.roomId)).data.participants
            && isMutualMingl(get(/databases/$(database)/documents/chatRooms/$(request.resource.data.roomId)).data.connectionId)
          ) ||
          !isNewMinglMessage()
        );
      allow update: if signedIn()
        && (
          !isExistingMinglMessage() ||
          isOwnMinglMessageEdit() ||
          isMinglReadReceiptUpdate() ||
          isMinglBackgroundConsentUpdate() ||
          isMinglDeleteAfterReadExpiry() ||
          (isExistingMinglMessage() && isDiagnosticParticipantResource())
        );
      allow delete: if signedIn()
        && (
          !isExistingMinglMessage() ||
          (isExistingMinglMessage() && isDiagnosticParticipantResource())
        );
    }
  }
}
